# LLM
OLLAMA_URL=http://localhost:11434
OLLAMA_DOCKER_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
GROQ_API_KEY=

# GitHub
GITHUB_TOKEN=

# Speech
WHISPER_MODEL=base
TTS_ENGINE=pyttsx3
TTS_VOICE=american_female
TTS_ESPEAK_VOICE=en-us+f3

# Local image generation
IMAGE_ENABLED=true
IMAGE_MODEL_ID=segmind/tiny-sd
IMAGE_DEVICE=auto
IMAGE_DEFAULT_STEPS=12
IMAGE_MAX_STEPS=20
IMAGE_DEFAULT_SIZE=512

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/calendar/google/callback
GOOGLE_FRONTEND_URL=http://localhost:5050
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_SYNC_TTL=300
GOOGLE_CALENDAR_MAX_EVENTS=8

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001
